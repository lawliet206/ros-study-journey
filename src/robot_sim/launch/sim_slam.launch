<!--
  sim_slam.launch — 仿真 SLAM 建图 (一键启动)
  ============================================
  功能: Gazebo 仿真 + gmapping 激光 SLAM 建图

  使用:
    roslaunch robot_sim sim_slam.launch

  操作:
    1. 启动后打开第二个终端
    2. rosrun teleop_twist_keyboard teleop_twist_keyboard.py
    3. 遥控小车在场地上绕圈建图
    4. 开 RViz: rviz (添加 Map + LaserScan + RobotModel)
    5. 建图完成后:
       rosrun map_server map_saver -f ~/maps/sim_map

  建图技巧:
    - 速度慢一点 (0.3~0.5 m/s), 太快激光数据会跳
    - 尽量覆盖所有区域, 绕边 + 内部来回
    - 在 RViz 中看着地图质量, 不够清晰就再绕一遍
-->
<launch>

  <arg name="world_file" default="$(find robot_sim)/worlds/room.world"/>
  <arg name="use_sim_time" default="true"/>
  <arg name="gui"          default="true"/>
  <arg name="paused"       default="false"/>

  <!-- ============================================================ -->
  <!-- 1. 仿真 (Gazebo + 机器人)                                       -->
  <!-- ============================================================ -->
  <include file="$(find robot_sim)/launch/simulation.launch">
    <arg name="world_file"   value="$(arg world_file)"/>
    <arg name="use_sim_time" value="$(arg use_sim_time)"/>
    <arg name="gui"          value="$(arg gui)"/>
    <arg name="paused"       value="$(arg paused)"/>
  </include>

  <!-- ============================================================ -->
  <!-- 2. gmapping SLAM                                               -->
  <!-- ============================================================ -->
  <node name="slam_gmapping" pkg="gmapping" type="slam_gmapping" output="screen">

    <!-- 帧 -->
    <param name="base_frame"  value="base_footprint"/>
    <param name="odom_frame"  value="odom"/>
    <param name="map_frame"   value="map"/>

    <!-- 地图范围 (~15m) -->
    <param name="xmin" value="-10"/>  <param name="ymin" value="-10"/>
    <param name="xmax" value="10"/>   <param name="ymax" value="10"/>
    <param name="delta" value="0.05"/>

    <!-- 激光 -->
    <param name="maxUrange" value="8.0"/>     <param name="maxRange" value="10.0"/>
    <param name="sigma"     value="0.05"/>    <param name="kernelSize" value="1"/>
    <param name="lstep"     value="0.05"/>    <param name="astep" value="0.05"/>
    <param name="iterations" value="5"/>      <param name="lsigma" value="0.075"/>
    <param name="ogain"     value="3.0"/>     <param name="lskip" value="0"/>
    <param name="minimumScore" value="50"/>

    <!-- 里程计噪声 (仿真里程计零噪声) -->
    <param name="srr" value="0.001"/>  <param name="srt" value="0.001"/>
    <param name="str" value="0.001"/>  <param name="stt" value="0.001"/>

    <!-- 粒子滤波 (15m 地图需要更多粒子) -->
    <param name="particles" value="80"/>
    <param name="linearUpdate" value="0.5"/>
    <param name="angularUpdate" value="0.2"/>
    <param name="resampleThreshold" value="0.5"/>
    <param name="transform_publish_period" value="0.05"/>
  </node>

</launch>
